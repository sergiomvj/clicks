APP_ENV=development
APP_DOMAIN=localhost
FRONTEND_PORT=3002
GRAFANA_PORT=3003
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://127.0.0.1:3002,http://localhost,http://127.0.0.1

POSTGRES_DB=fbr_clicks
POSTGRES_USER=fbr_clicks
POSTGRES_PASSWORD=fbr_clicks
DATABASE_URL_ASYNCPG=postgresql://fbr_clicks:fbr_clicks@postgres:5432/fbr_clicks
REDIS_URL=redis://redis:6379/0

SESSION_SECRET=replace-with-64-char-session-secret
JWT_SECRET=replace-with-agent-jwt-secret
OPENCLAW_AGENT_JWT_SECRET=replace-with-openclaw-jwt-secret

BACKEND_URL=http://fastapi:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

DASHBOARD_EMAIL=admin@fbr.local
DASHBOARD_PASSWORD=change-me-now
DASHBOARD_USER_ID=11111111-1111-1111-1111-111111111111
DASHBOARD_WORKSPACE_ID=00000000-0000-0000-0000-000000000001

OPENCLAW_PORT=3500
OPENCLAW_WORKSPACE_ID=00000000-0000-0000-0000-000000000001
OPENCLAW_GATEWAY_URL=http://openclaw-gateway:3500

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_SECONDS=15
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_SECONDS=30
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT_SECONDS=30

FBR_LEADS_WEBHOOK_SECRET=replace-with-fbr-leads-secret
FBR_DEV_WEBHOOK_SECRET=replace-with-fbr-dev-secret
FBR_SUPORTE_WEBHOOK_SECRET=replace-with-fbr-suporte-secret
FBR_LEADS_API_URL=http://host.docker.internal:8010
FBR_DEV_API_URL=http://host.docker.internal:8020
FBR_SUPORTE_API_URL=http://host.docker.internal:8030



